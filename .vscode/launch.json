    "configurations": [                        
          {
            "name": "Python: Fast File",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",                 // 关键：直接跑当前打开的文件
            "console": "integratedTerminal",
            "cwd": "${fileDirname}",              // 关键：把工作目录设为当前文件所在目录
            "envFile": "${workspaceFolder}/.env.dev", // 可选：读取你的环境变量
            "justMyCode": true
          }          
    ],
    "compounds": [
        
      ]   
}